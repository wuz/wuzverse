{
	"name": "wuz-monorepo",
	"version": "0.0.0",
	"private": true,
	"workspaces": [
		"sites/*",
		"packages/*"
	],
	"type": "module",
	"scripts": {
		"build:wuz-sh": "turbo run build --filter=@wuz/wuz-sh",
		"build:wuz-quest": "turbo run build --filter=@wuz/wuz-quest",
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "turbo run lint",
		"format": "oxfmt .",
		"format:check": "oxfmt --check .",
		"deploy:wuz-sh": "turbo run deploy --filter=@wuz/wuz-sh",
		"deploy:wuz-quest": "turbo run deploy --filter=@wuz/wuz-quest",
		"deploy:all": "turbo run deploy"
	},
	"devDependencies": {
		"oxfmt": "^0.58.0",
		"oxlint": "^1.73.0",
		"turbo": "^2.5.4"
	},
	"packageManager": "bun@1.3.13",
	"trustedDependencies": [
		"esbuild",
		"@esbuild/darwin-arm64"
	]
}
