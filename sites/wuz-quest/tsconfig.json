{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"plugins": [{ "name": "next" }],
		"paths": {
			"@/*": ["./src/*"],
			"@content/*": ["./content/*"],
			"content-collections": ["./.content-collections/generated"]
		}
	},
	"include": [
		"cloudflare-env.d.ts",
		"next-env.d.ts",
		"**/*.ts",
		"**/*.tsx",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts"
	],
	"exclude": ["node_modules", "scripts"]
}
