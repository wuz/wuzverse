{
	"$schema": "https://turbo.build/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".next/**", "!.next/cache/**", ".open-next/**", "dist/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"lint": {
			"outputs": []
		},
		"cf-build": {
			"dependsOn": ["build"],
			"outputs": [".open-next/**"]
		},
		"deploy": {
			"dependsOn": ["cf-build"],
			"cache": false,
			"passThroughEnv": ["CLOUDFLARE_API_TOKEN", "CLOUDFLARE_ACCOUNT_ID"]
		},
		"preview": {
			"dependsOn": ["cf-build"],
			"cache": false
		}
	}
}
